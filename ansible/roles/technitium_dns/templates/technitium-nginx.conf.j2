# ==============================================================================
# File: /etc/nginx/sites-available/technitium.conf
# Purpose: Management-only HTTPS reverse proxy for Technitium DNS.
# Managed by Ansible.
# ==============================================================================

server {
    listen {{ technitium_tls_proxy_port }} ssl http2;
    server_name {{ inventory_hostname }}.fouchger.uk {{ ansible_host }};

    ssl_certificate /etc/technitium/tls/technitium.crt;
    ssl_certificate_key /etc/technitium/tls/technitium.key;
    ssl_protocols TLSv1.2 TLSv1.3;

    access_log /var/log/nginx/technitium-access.log;
    error_log /var/log/nginx/technitium-error.log warn;

    location / {
        proxy_pass http://127.0.0.1:{{ technitium_web_port }};
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
        proxy_read_timeout 90s;
    }
}
